# Gitignore for Spring Boot microservices (Maven / Gradle)

# Build output
/target/
**/target/
build/
**/build/
out/

# Maven
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber
.mvn/timing.properties

# Gradle
.gradle/
gradle-app.setting
!gradle/wrapper/gradle-wrapper.jar
gradle-wrapper.properties

# Java artifacts
*.class
*.jar
*.war
*.ear
*.nar
hs_err_pid*
replay_pid*

# Log files
*.log
logs/
nohup.out

# Spring Boot specific
/*.jar
/*.war
*.pid
spring-boot-app.log

# IDEs
## IntelliJ
.idea/
*.iml
*.iws
workspace.xml
tasks.xml
usage.statistics.xml
dictionaries/

## Eclipse / STS
.project
.classpath
.settings/
.apt_generated/
.factorypath
.recommenders/
.metadata/

## VS Code
.vscode/

## NetBeans
nbproject/private/
build/
nbbuild/
dist/
nblibraries/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Temporary / swap
*~
*.swp
*.swo

# Docker / Compose
.env
docker-compose.override.yml
docker-compose.*.yml
**/docker-compose.override.yml

# Kubernetes / Helm local artifacts
.kube/
helm-debug/
*.kubeconfig

# Certificates / keys
*.jks
*.keystore
*.crt
*.pem
*.key

# Dependency directories (frontend inside services)
node_modules/
jspm_packages/
bower_components/

# Frontend builds
dist/
build/
coverage/
.nyc_output/

# CI / packaging
.release/
*.gem
*.tar.gz

# Misc
.idea_modules/
.coverage
.cache/
*.log.*
.terraform/

# Keep custom local configs out of VCS
application-local.properties
application-local.yml
application-*.local.yml
local.env
secrets.yml